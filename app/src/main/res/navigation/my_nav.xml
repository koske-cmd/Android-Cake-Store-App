<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_nav"
    app:startDestination="@id/startFragment">

    <fragment
        android:id="@+id/kolacFragment"
        android:name="com.metropolitan.prodavnica_pz.views.KolacFragment"
        android:label="Kolači"
        tools:layout="@layout/fragment_kolac">
        <action
            android:id="@+id/action_kolacFragment_to_productFragment"
            app:destination="@id/productFragment" />
        <action
            android:id="@+id/action_kolacFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>
    <fragment
        android:id="@+id/productFragment"
        android:name="com.metropolitan.prodavnica_pz.views.ProductFragment"
        android:label="Vaša poslastica"
        tools:layout="@layout/fragment_product">
        <action
            android:id="@+id/action_productFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>
    <fragment
        android:id="@+id/cartFragment"
        android:name="com.metropolitan.prodavnica_pz.views.CartFragment"
        android:label="Vaša korpa"
        tools:layout="@layout/fragment_cart">
        <action
            android:id="@+id/action_cartFragment_to_orderFragment"
            app:destination="@id/orderFragment" />
    </fragment>
    <fragment
        android:id="@+id/orderFragment"
        android:name="com.metropolitan.prodavnica_pz.views.OrderFragment"
        android:label="Narudžbenica"
        tools:layout="@layout/fragment_order" >
        <action
            android:id="@+id/action_orderFragment_to_startFragment"
            app:destination="@id/startFragment" />
    </fragment>
    <fragment
        android:id="@+id/tortaFragment"
        android:name="com.metropolitan.prodavnica_pz.views.TortaFragment"
        android:label="Torte"
        tools:layout="@layout/fragment_torta">
        <action
            android:id="@+id/action_tortaFragment_to_productFragment"
            app:destination="@id/productFragment" />
        <action
            android:id="@+id/action_tortaFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>
    <fragment
        android:id="@+id/startFragment"
        android:name="com.metropolitan.prodavnica_pz.views.StartFragment"
        android:label="Kolači i torte"
        tools:layout="@layout/fragment_start">
        <action
            android:id="@+id/action_startFragment_to_tortaFragment"
            app:destination="@id/tortaFragment" />
        <action
            android:id="@+id/action_startFragment_to_kolacFragment"
            app:destination="@id/kolacFragment" />
    </fragment>
</navigation>